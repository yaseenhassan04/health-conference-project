generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
model Library {
  id          Int      @id @default(autoincrement())
  title       String
  author      String   @default("")
  category    String   @default("General")
  type        String   @default("book")
  fileUrl     String   @default("")
  description String   @default("")
  year        Int      @default(2026)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
}
model User {
  id         Int        @id @default(autoincrement())
  fullName   String
  email      String     @unique
  profession String
  country    String
  createdAt  DateTime   @default(now())
  attended   Boolean    @default(false)
  abstracts  Abstract[]
}

model Abstract {
  id             Int       @id @default(autoincrement())
  title          String
  authorName     String
  email          String
  pdfUrl         String
  category       String    @default("General")
  status         String    @default("PENDING")
  submitterId    Int?
  submissionDate DateTime  @default(now())
  createdAt      DateTime  @default(now())
  submitter      User?     @relation(fields: [submitterId], references: [id])
  reviews        Review[]
}

model Reviewer {
  id             Int      @id @default(autoincrement())
  name           String
  specialty      String
  maxAssignments Int      @default(5)
  createdAt      DateTime @default(now())
  reviews        Review[]
}

model Review {
  id             Int      @id @default(autoincrement())
  abstractId     Int
  reviewerId     Int
  scientificScore Int?
  comments       String?
  internalNotes  String?
  decision       String?
  createdAt      DateTime @default(now())
  abstract       Abstract @relation(fields: [abstractId], references: [id])
  reviewer       Reviewer @relation(fields: [reviewerId], references: [id])
}

model Question {
  id        Int      @id @default(autoincrement())
  text      String
  author    String   @default("Anonymous")
  createdAt DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
model GalleryMedia {
  id        Int      @id @default(autoincrement())
  src       String
  captionAr String
  captionEn String   @default("")
  tag       String   @default("فعاليات")
  tagEn     String   @default("Events")
  createdAt DateTime @default(now())
}

model GalleryScreen {
  id        Int      @id @default(autoincrement())
  type      String   @default("link")
  titleAr   String
  titleEn   String   @default("")
  descAr    String   @default("")
  descEn    String   @default("")
  icon      String   @default("🖥️")
  href      String   @default("/media")
  mediaUrl  String   @default("")
  embedCode String   @default("")
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  date      String
  icon      String   @default("📰")
  content   String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}